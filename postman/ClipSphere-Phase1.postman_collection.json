    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const stamp = Date.now();",
                  "const username = `postman_user_${stamp}`;",
                  "const email = `postman_user_${stamp}@clipsphere.local`;",
                  "pm.environment.set(\"registerUsername\", username);",
                  "pm.environment.set(\"registerEmail\", email);",
                  "pm.environment.set(\"registerPassword\", \"UserPass123!\");"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "const token = json?.data?.token;",
                  "const userId = json?.data?.user?.id;",
                  "if (token) pm.environment.set(\"jwt_token\", token);",
                  "if (userId) pm.environment.set(\"userId\", userId);",
                  "if (pm.environment.get(\"userId\") && !pm.environment.get(\"targetUserId\")) {",
                  "  pm.environment.set(\"targetUserId\", pm.environment.get(\"userId\"));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registerUsername}}\",\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "POST /api/v1/auth/login (User)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@clipsphere.local\",\n  \"password\": \"UserPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "const token = json?.data?.token;",
                  "const userId = json?.data?.user?.id;",
                  "pm.test(\"JWT token exists\", function () {",
                  "  pm.expect(token).to.be.a(\"string\");",
                  "});",
                  "if (token) pm.environment.set(\"jwt_token\", token);",
                  "if (userId) pm.environment.set(\"userId\", userId);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@clipsphere.local\",\n  \"password\": \"AdminPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "const token = json?.data?.token;",
                  "const adminUserId = json?.data?.user?.id;",
                  "pm.test(\"Admin JWT exists\", function () {",
                  "  pm.expect(token).to.be.a(\"string\");",
                  "});",
                  "if (token) pm.environment.set(\"admin_jwt_token\", token);",
                  "if (adminUserId) pm.environment.set(\"adminUserId\", adminUserId);"
                ]
              }
            }
          ]
        }
